# Regulus Automation Inc. — environment variables (example)
# Copy to `.env.local` and fill in as needed. NEVER commit real secrets.
# The site builds and runs with NO variables set; all below are optional.

# --- Public (safe to expose; compiled into the client bundle) -----------------

# Canonical site origin. If unset, the value in src/lib/site.ts is used.
# Used for canonical URLs, sitemap, robots, and Open Graph tags.
NEXT_PUBLIC_SITE_URL=https://regulusautomation.ca

# --- Build / tooling ----------------------------------------------------------

# Disable Next.js anonymous telemetry during CI/builds.
NEXT_TELEMETRY_DISABLED=1

# --- Optional: contact backend (not required for the current mailto flow) -----
# Only needed if you wire src/app/api/contact to a real handler (see CONTENT.md).
# These are SERVER-side (no NEXT_PUBLIC_ prefix) — keep any real value secret.

# POST target for server-side contact submissions (email/CRM webhook).
# CONTACT_ENDPOINT=

# Shared secret / API key for the contact endpoint (SECRET — never hard-code).
# CONTACT_API_KEY=
